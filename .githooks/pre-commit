#!/usr/bin/env bash
# Pre-commit gate: run the fast tessl review gate against any plugin that has
# staged changes. Skips instantly when no skill files are touched, so ordinary
# commits aren't blocked on a network call.
#
# Enable once with:  git config core.hooksPath .githooks
# Bypass in a pinch:  git commit --no-verify
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Find plugin dirs (those containing .tessl-plugin/plugin.json) that own a
# staged file. Walk each staged path up to the repo root looking for a marker.
changed=""
while IFS= read -r f; do
  d="$f"
  while [ -n "$d" ] && [ "$d" != "." ]; do
    if [ -f "$d/.tessl-plugin/plugin.json" ]; then
      case " $changed " in *" $d "*) : ;; *) changed="$changed $d" ;; esac
      break
    fi
    d="$(dirname "$d")"
  done
done < <(git diff --cached --name-only)

# shellcheck disable=SC2086
if [ -z "${changed// }" ]; then
  exit 0
fi

echo "tessl pre-commit gate: reviewing changed plugins:${changed}"
# shellcheck disable=SC2086
exec "$repo_root/scripts/tessl-review-gate.sh" $changed
