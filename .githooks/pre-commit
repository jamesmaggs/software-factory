#!/usr/bin/env bash
# Lint every SKILL.md against the Agent Skills spec before each commit.
# Deterministic and offline — if it can't run, stop and investigate; don't bypass.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
linter="$repo_root/skills/skill-linter/scripts/lint_skill.sh"

echo "pre-commit: linting skills…"
status=0
# Top-level skills only — evals/files/* hold intentionally malformed fixtures.
for skill_md in "$repo_root"/skills/*/SKILL.md; do
  [ -e "$skill_md" ] || continue
  bash "$linter" "$skill_md" || status=1
done
exit "$status"
